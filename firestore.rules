rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, < 100 chars)
    //   - category: string (required, in ['Ladies', 'Gents', 'Kids', 'Others'])
    //   - price: string (optional, < 50 chars)
    //   - desc: string (optional, < 2000 chars)
    //   - images: list of strings (required, size <= 10, each < 2MB)
    //   - createdAt: number (required, immutable)
    //   - authorUID: string (required, immutable)
    //
    // Collection: users
    // Document ID: user UID
    // Fields:
    //   - email: string (required)
    //   - role: string (required, in ['admin'])
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "niyasusan8@gmail.com" && request.auth.token.email_verified == true) ||
        (request.auth.token.email == "admin@cosmofibers.com") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorUID;
    }

    function uidUnchanged() {
      return !('authorUID' in request.resource.data) || request.resource.data.authorUID == request.auth.uid;
    }

    function uidNotModified() {
      return !('authorUID' in request.resource.data) || 
             !('authorUID' in resource.data) || 
             request.resource.data.authorUID == resource.data.authorUID;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    function isValidList(listField, maxSize) {
      return request.resource.data[listField] is list && request.resource.data[listField].size() <= maxSize;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidProduct() {
      return hasOnlyAllowedFields(['name', 'category', 'price', 'desc', 'images', 'externalLink', 'createdAt', 'authorUID']) &&
             hasRequiredFields(['name', 'category', 'images', 'createdAt', 'authorUID']) &&
             validStringLength('name', 1, 100) &&
             request.resource.data.category in ['Ladies', 'Gents', 'Kids', 'Hangers', 'Others'] &&
             isValidOptionalString('price', 0, 50) &&
             isValidOptionalString('desc', 0, 2000) &&
             isValidOptionalString('externalLink', 0, 2000) &&
             isValidList('images', 10) &&
             request.resource.data.createdAt is number &&
             request.resource.data.authorUID is string;
    }

    function isValidUser() {
      return hasOnlyAllowedFields(['email', 'role']) &&
             hasRequiredFields(['email', 'role']) &&
             request.resource.data.email is string &&
             request.resource.data.role in ['admin'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      // Anyone can read products
      allow read: if true;
      
      // Only admins can create products
      allow create: if isAdmin() && 
                       isValidProduct() && 
                       uidUnchanged();
                       
      // Only admins can update products. authorUID and createdAt must not change.
      allow update: if isAdmin() && 
                       isValidProduct() && 
                       uidNotModified() &&
                       (!('createdAt' in resource.data) || request.resource.data.createdAt == resource.data.createdAt);
                       
      // Only admins can delete products
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      // Only admins can read the users collection
      allow read: if isAdmin();
      
      // Only admins can create/update other admins
      allow create: if isAdmin() && isValidUser() && request.auth.uid == userId;
      allow update: if isAdmin() && isValidUser() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
